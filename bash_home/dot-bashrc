#!/bin/bash

bashrc_restore_expand_aliases=$(shopt -p expand_aliases)
shopt -u expand_aliases

source ~/.philconfig/shell_lib/bash_debug.sh
source ~/.philconfig/shell_rc_common
source ~/.philconfig/shell_rc.bash.home
source ~/.philconfig/shell_rc.bash
source ~/.philconfig/shell_lib/functions.sh
if [[ -r /opt/homebrew/Cellar/lmod/9.1.2/init/profile ]] ; then
    source /opt/homebrew/Cellar/lmod/9.1.2/init/profile
fi

if [[ -t 0 ]] ; then
    cat ~/.login-image.txt >&2
fi
. "$HOME/.cargo/env"

${bashrc_restore_expand_aliases}
unset bashrc_restore_expand_aliases
